# ---------------------------------------------------------------------------
# 환경 분리 (이 저장소의 next.config.ts 기준)
# • 로컬 `npm run dev` → 루트의 .env.local 만 사용 (.env 값은 적용되지 않음)
# • 운영 `next build` / `next start` / Cloud Run → 루트의 .env 만 사용
# 처음 설정: 아래 내용으로 .env.example 을 참고해 .env.local 과 .env 를 각각 만드세요.
# ---------------------------------------------------------------------------

# Supabase (Supabase 대시보드 > Project Settings > API에서 복사)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 운영: 위 두 줄만 .env 에 맞추면 됩니다. ./scripts/deploy.sh 가 Cloud Run에 런타임용 복제 키(SERVER_SUPABASE_PUBLIC_*)를 자동으로 같이 넣습니다.

# 관리자 기능(포인트 지급, 인증 심사, 기부처 등) 사용 시 필수. 같은 API 페이지에서 service_role 키 복사
# SUPABASE_SERVICE_ROLE_KEY=

# 로그인 없이 테스트할 때만: 003-guest-test-user.sql 실행 후 아래 둘 다 설정
# GUEST_TEST_USER_ID=guest-test
# (위 SUPABASE_SERVICE_ROLE_KEY도 필요)

# 프로덕션 배포 주소 (스킴 포함). Cloud Run/실서버 빌드·실행 시에만 사용됨.
# 로컬 `npm run dev`는 항상 http://localhost:3000 으로 OAuth 리다이렉트 (이 값과 무관).
NEXT_PUBLIC_APP_URL=https://your-production-domain.example

# (선택) 로컬 개발 중에만 다른 베이스 URL을 쓸 때 (ngrok 등). 비우면 localhost:3000.
# NEXT_PUBLIC_DEV_APP_URL=https://xxxx.ngrok-free.app

# Google Analytics 4 측정 ID (GA4 > 관리자 > 데이터 스트림에서 확인)
# 예: G-PRVLFS3GX2
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 구글 챗 에러 알림 (스페이스 > 앱 및 통합 > 웹훅 추가 후 URL 복사. 서버 전용 — NEXT_PUBLIC_ 붙이지 말 것)
# 로컬: .env.local / Cloud Run 배포: 루트 .env 에 동일 키로 넣어야 ./scripts/deploy.sh 가 전달함
# GOOGLE_CHAT_WEBHOOK_URL=

# 구글 챗 관리자 운영 알림 (예: 승인 대기 알림 전용 스페이스)
# 이벤트 인증 제출 등 "운영 알림"은 이 웹훅으로 전송됨
# GOOGLE_CHAT_ADMIN_WEBHOOK_URL=

# 세아웍스 인사 연동 REST API (VNTG 그룹웨어서비스팀 정선우 담당자 발급)
# 부서명(dept_name), 프로필 이미지 등 동기화용. 정의서 참고하여 API 호출.
# system_id: VTOGETHER
SEAH_ORGSYNC_USER_API_URL=   # 사용자 정보 API URL (정의서에서 확인)
SEAH_ORGSYNC_ORG_API_URL=    # 조직도 API URL (정의서에서 확인)
SEAH_ORGSYNC_USERNAME=       # 개발: GW_DEV_ORGSYNC / 운영: GW_PRD_ORGSYNC
SEAH_ORGSYNC_PASSWORD=       # VNTG 그룹웨어서비스팀에서 발급받은 비밀번호
SEAH_ORGSYNC_CRON_SECRET=    # /api/cron/seah-orgsync 보호용 Bearer 토큰 (랜덤 긴 문자열 권장)
